{
  "version": 2,
  "functions": {
    "server/api/index.js": {
      "includeFiles": "server/src/assets/templates/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/api/index.js" },
    { "source": "/(.*)", "destination": "/client/$1" },
    { "handle": "filesystem" },
    { "source": "/(.*)", "destination": "/client/index.html" }
  ]
}
